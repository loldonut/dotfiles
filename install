#!/usr/bin/env bash

set -e

HOME_DIR="$HOME"

STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/dotfiles"
STAMP_FILE="$STATE_DIR/.initialized"

DEPS=(
    stow
    zsh
    tmux
    neovim
    alacritty
    rofi
    grim
    slurp
    swappy
    mangohud
    blueman
    wl-clipboard
    cliphist
    fish
    qt5-wayland
    qt6-wayland
    zoxide
    starship
    xdg-desktop-portal
    xdg-desktop-portal-hyprland
    xdg-desktop-portal-gtk
    network-manager-applet
    dolphin
    kitty
    swaync
    hyprshot
    hyprpaper
    hyprshutdown
    waypaper
    wayle
    hyprpolkitagent
    ghostty
    brave-bin
    matugen
)

FONT_DEPS=(
    noto-fonts-cjk
    ttf-jetbrains-mono-nerd
    ttf-adwaitamono-nerd
)

log() {
    printf "\e[1;32m[dotfiles]\e[0m %s\n" "$*";
}

log_die() {
    printf "\e[1;32m[dotfiles]\e[0m %s\n" "$*" >&2;
    exit 1
}

log_warn() {
    printf "\e[1;33m[dotfiles]\e[0m %s\n" "$*"
}

require() {
    command -v "$1" &>/dev/null || log_die "'$1' is not installed."
}

install_deps() {
    if [[ -f "${STAMP_FILE}" ]]; then
        log_warn "dotfiles has already been initialized."
        log_die "exiting.."
    fi

    # Install yay if missing
    if ! command -v yay &>/dev/null; then
        log "yay not found. Installing yay from AUR..."
        local tmp_dir
        tmp_dir="$(mktemp -d)"
        git clone --depth=1 https://aur.archlinux.org/yay-bin.git "$tmp_dir"
        (cd "$tmp_dir" && makepkg -si --noconfirm)
        rm -rf "$tmp_dir"
    fi

    log "Installing dependencies..."
    yay -S --needed --noconfirm "${DEPS[@]}"

    log "Installed required dependencies."
    printf "\e[1;34m[dotfiles]\e[0m Install fonts? (noto-fonts-cjk ttf-jetbrains-mono-nerd ttf-adwaitamono-nerd) [Y/n] "
    read -r reply
    if [[ -z "${reply}" || "${reply,,}" == "y" ]]; then
        log "Installing fonts..."
        yay -S --needed --noconfirm "${FONT_DEPS[@]}"
        log "Fonts installed."
    else
        log "Skipping font installation."
    fi
}

init_matugen() {
    local wallpaper="$1"
    local fallback_source_color="#1a1b26"

    if [[ -z "$wallpaper" ]]; then
        log "No wallpaper found. Running matugen without an image source."
        log "Pass a wallpaper path as the first argument to override, e.g.:"
        log "  $0 /path/to/wallpaper.jpg"
        matugen color hex "${fallback_source_color}" --verbose
    elif [[ ! -f "$wallpaper" ]]; then
        log "Detected wallpaper path does not exist: ${wallpaper}"
        log "Using fallback source color."
        matugen color hex "${fallback_source_color}" --verbose
    else
        log "Generating theme from: ${wallpaper}"
        matugen image "${wallpaper}" --verbose
    fi
}

check_wallpaper_folder() {
    if [[ ! -e "${HOME_DIR}/Pictures/Wallpapers" ]]; then
        log "No wallpaper folder found. Creating one.."

        mkdir -p "${HOME_DIR}/Pictures/Wallpapers"

        log "Created wallpaper folder.\n"
    fi
}

stow_it() {
    require "stow"
    require "matugen"

    # TODO: auto-detect dotfiles directory, or just use the 'pwd' command
    if [[ ! -d "$HOME/dotfiles" ]]; then
        log_die "Dotfiles is not in HOME directory, exiting."
    fi

    find "${HOME}/dotfiles/dots/home" -maxdepth 1 -mindepth 1 -print0 | while IFS= read -r -d '' pkg; do
        log "Stowing ${pkg} -> ${HOME_DIR}"
        log "$pkg"
        stow --dir="${HOME}/dotfiles/dots/home" \
            --target="${HOME_DIR}" \
            "$(basename "${pkg}")"
    done

    stow --dir="$HOME/dotfiles" --target="$HOME_DIR" --ignore="home" -R dots \
        && log "Stowed .config and .local directory"

    mkdir -p "${STATE_DIR}"
    local override_wallpaper="${1:-}"

    if [[ ! -f "${STAMP_FILE}" ]]; then
        log "First run detected. Initializing matugen theme."

        local wallpaper
        if [[ -n "${override_wallpaper}" ]]; then
            wallpaper="${override_wallpaper}"
            echo "Using wallpaper: ${override_wallpaper}"
        fi

        check_wallpaper_folder

        log "Initializing matugen colors"
        init_matugen "${wallpaper}"
        touch "${STAMP_FILE}"
    else
        if [[ -n "${override_wallpaper}" ]]; then
            log "Ignoring given wallpaper path. Use the 'SUPER + SHIFT + W' bind instead."
        fi
        log "Matugen has already been initialized. Doing nothing."
    fi
}

install_deps
stow_it "$@"

