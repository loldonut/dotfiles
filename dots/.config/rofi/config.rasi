configuration {
  show-icons: true;
  modes: [ drun, combi ];
  combi-modes: [ drun, run ];
  font: "JetBrainsMono Nerd Font 12";
}

entry {
  placeholder: "Type here";
  cursor: pointer;
  background-color: black;
}

element {
  orientation: horizontal;
  children: [ element-text, element-icon ];
  spacing: 5px;
}

@import "colors.rasi"
